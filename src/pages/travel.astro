---
import BaseLayout from '../layouts/BaseLayout.astro';

const GUIDES = [
  { title: '48 Hours in Tokyo: A Complete Guide', cat: 'Asia · Japan',              meta: 'Oct 2025 · 14 days', img: 'https://images.unsplash.com/photo-1540959733332-eab4deabeeaf?w=700&h=500&auto=format&fit=crop&q=82' },
  { title: 'Patagonia: A Complete Itinerary',      cat: 'South America · Argentina', meta: 'Feb 2025 · 8 days',  img: 'https://images.unsplash.com/photo-1501854140801-50d01698950b?w=700&h=500&auto=format&fit=crop&q=82' },
  { title: 'Amalfi Coast in 5 Days',               cat: 'Europe · Italy',            meta: 'Jul 2024 · 5 days',  img: 'https://images.unsplash.com/photo-1533104816931-20fa691ff6ca?w=700&h=500&auto=format&fit=crop&q=82' },
  { title: 'Kyoto Temple Walking Guide',            cat: 'Asia · Japan',              meta: 'Apr 2024 · 6 days',  img: 'https://images.unsplash.com/photo-1493976040374-85c8e12f0c0e?w=700&h=500&auto=format&fit=crop&q=82' },
  { title: 'A Weekend in the Dolomites',            cat: 'Europe · Italy',            meta: 'Sep 2023 · 3 days',  img: 'https://images.unsplash.com/photo-1469474968028-56623f02e42e?w=700&h=500&auto=format&fit=crop&q=82' },
  { title: 'The Best Coffee Shops in London',       cat: 'Europe · UK',               meta: 'Nov 2023 · 4 days',  img: 'https://images.unsplash.com/photo-1501339847302-ac426a4a7cbb?w=700&h=500&auto=format&fit=crop&q=82' },
];

const MISADVENTURES = [
  { title: 'Stranded in Kyoto at 3 AM',              note: 'no taxis, no trains, no Japanese',      gps: '35.0116, 135.7681',  img: 'https://images.unsplash.com/photo-1493976040374-85c8e12f0c0e?w=600&h=750&auto=format&fit=crop&q=80',  h: 320 },
  { title: 'Why I Hated Paris',                       note: 'sorry not sorry',                       gps: '48.8566, 2.3522',    img: 'https://images.unsplash.com/photo-1502602898657-3e91760cbb34?w=600&h=420&auto=format&fit=crop&q=80',  h: 260 },
  { title: 'A Conversation with a Stranger on a Train to Nowhere', note: 'he was right about everything', gps: '-41.1456, -71.3082', img: 'https://images.unsplash.com/photo-1474487548417-781cb71495f3?w=600&h=900&auto=format&fit=crop&q=80',  h: 380 },
  { title: "The Hotel That Wasn't a Hotel",           note: "someone's grandmother's spare room",    gps: '40.8518, 14.2681',   img: 'https://images.unsplash.com/photo-1533104816931-20fa691ff6ca?w=600&h=600&auto=format&fit=crop&q=80',  h: 300 },
  { title: 'I Got Robbed by a Monkey',               note: 'he won, fair and square',               gps: '-8.5069, 115.2625',  img: 'https://images.unsplash.com/photo-1540959733332-eab4deabeeaf?w=600&h=420&auto=format&fit=crop&q=80',  h: 270 },
  { title: 'The Patagonian Wind Almost Killed Me',   note: '90 km/h sideways. no shelter.',         gps: '-49.2742, -73.0420', img: 'https://images.unsplash.com/photo-1501854140801-50d01698950b?w=600&h=750&auto=format&fit=crop&q=80',  h: 360 },
  { title: 'A Bar with No Name in Amalfi',           note: 'they served us limoncello at 11 AM',    gps: '40.6340, 14.6027',   img: 'https://images.unsplash.com/photo-1469474968028-56623f02e42e?w=600&h=520&auto=format&fit=crop&q=80',  h: 290 },
  { title: 'The Train I Missed on Purpose',          note: 'best decision of the trip',             gps: '?, ?',               img: 'https://images.unsplash.com/photo-1480796927426-f609979314bd?w=600&h=900&auto=format&fit=crop&q=80',  h: 400 },
];

const MAP_PINS = [
  { x: 75, y: 55, label: 'Tokyo' },
  { x: 48, y: 42, label: 'London' },
  { x: 52, y: 48, label: 'Amalfi' },
  { x: 78, y: 58, label: 'Kyoto' },
  { x: 30, y: 82, label: 'Patagonia' },
  { x: 52, y: 38, label: 'Dolomites' },
];
---

<BaseLayout title="Travel — The Null Hypothesis" activeNav="travel">

  <!-- H₀: itinerary -->
  <div class="h0x">
    <div class="page-header">
      <div class="page-eyebrow">H₀ · The Itinerary</div>
      <h1 class="page-title">Travel</h1>
      <p class="page-sub">Where to go, what to eat, and how to do it in 48 hours. The clean version, with timestamps.</p>
    </div>

    <div class="t-map">
      <svg class="t-map-svg" viewBox="0 0 100 100" preserveAspectRatio="none">
        <path d="M5,55 Q20,40 35,52 T60,48 Q72,55 88,42 L95,50 L95,80 L5,80 Z" fill="var(--s1)" stroke="var(--border)" stroke-width=".3"/>
        <path d="M10,30 Q25,35 40,28 T70,30 Q82,28 92,35" fill="none" stroke="var(--border)" stroke-width=".3" stroke-dasharray="1,1"/>
      </svg>
      {MAP_PINS.map(pin => (
        <>
          <span class="t-map-pin"  style={`left:${pin.x}%;top:${pin.y}%;`}></span>
          <span class="t-map-label" style={`left:${pin.x}%;top:${pin.y}%;`}>{pin.label}</span>
        </>
      ))}
    </div>

    <div class="t-hidden-reveal">The map is not the territory. Find the alternative.</div>

    <div class="t-grid-page">
      {GUIDES.map(g => (
        <a class="t-guide" href="#">
          <div class="t-guide-img" style={`background-image:url('${g.img}')`}></div>
          <div class="t-guide-body">
            <div class="t-guide-cat">{g.cat}</div>
            <div class="t-guide-title">{g.title}</div>
            <div class="t-guide-meta">{g.meta}</div>
          </div>
        </a>
      ))}
    </div>
  </div>

  <!-- H₁: misadventures masonry -->
  <div class="h1x">
    <div class="page-header">
      <div class="page-eyebrow">H₁ · The Misadventures</div>
      <h1 class="page-title">What Actually Happened</h1>
      <p class="page-sub">Stranded. Robbed. Lost. Wrong. The trips that didn't make the guidebook — and the only ones worth telling.</p>
    </div>

    <div class="t-masonry">
      {MISADVENTURES.map(m => (
        <a class="t-mess" href="#">
          <div class="t-mess-img" style={`background-image:url('${m.img}');height:${m.h}px;`}></div>
          <div class="t-mess-cap">{m.title}</div>
          <div class="t-mess-note">{m.note}</div>
          <div class="t-mess-gps">{m.gps}</div>
        </a>
      ))}
    </div>
  </div>

  <footer>
    <div class="footer-left">
      <div class="footer-name">The Null Hypothesis</div>
      <div class="footer-tag h0x">Reject the null.</div>
      <div class="footer-tag h1x">H₁ confirmed.</div>
    </div>
    <div class="footer-links">
      <a href="/">About</a>
      <a href="/writing">Writing</a>
    </div>
  </footer>

</BaseLayout>
